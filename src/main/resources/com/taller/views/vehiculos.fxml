<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.taller.controllers.VehiculoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Gestión de Vehículos" textFill="WHITE">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <HBox spacing="10.0" alignment="CENTER">
        <ComboBox fx:id="cmbTipo" promptText="Tipo de Vehículo" prefWidth="150.0" onAction="#onTipoSeleccionado" />
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
        <TextField fx:id="txtPlaca" promptText="Placa" prefWidth="100.0" disable="true" />
        <TextField fx:id="txtMarca" promptText="Marca" prefWidth="120.0" disable="true" />
        <TextField fx:id="txtModelo" promptText="Modelo" prefWidth="120.0" disable="true" />
        <TextField fx:id="txtAnio" promptText="Año" prefWidth="80.0" disable="true" />
        <TextField fx:id="txtCedulaCliente" promptText="Cédula Dueño" prefWidth="120.0" disable="true" />
        
        <!-- Campos Específicos -->
        <TextField fx:id="txtCilindraje" promptText="Cilindraje (cc)" prefWidth="100.0" visible="false" managed="false" />
        <TextField fx:id="txtNumPuertas" promptText="Num Puertas" prefWidth="100.0" visible="false" managed="false" />
        <TextField fx:id="txtCapacidadCarga" promptText="Carga (Ton)" prefWidth="100.0" visible="false" managed="false" />

        <Button fx:id="btnGuardar" text="Guardar" onAction="#guardarVehiculoAction" style="-fx-background-color: #2980b9; -fx-text-fill: white;" disable="true">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>
    </HBox>

    <TableView fx:id="tablaVehiculos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTipo" text="Tipo" prefWidth="80.0" />
            <TableColumn fx:id="colPlaca" text="Placa" prefWidth="100.0" />
            <TableColumn fx:id="colMarca" text="Marca" prefWidth="130.0" />
            <TableColumn fx:id="colModelo" text="Modelo" prefWidth="130.0" />
            <TableColumn fx:id="colAnio" text="Año" prefWidth="70.0" />
            <TableColumn fx:id="colCedulaCliente" text="DNI Dueño" prefWidth="120.0" />
            <TableColumn fx:id="colExtra" text="Detalle Extra" prefWidth="150.0" />
        </columns>
    </TableView>
</VBox>
