<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.taller.controllers.FacturacionController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Nueva Factura" styleClass="title-label">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <HBox spacing="20.0" alignment="CENTER">
        <VBox spacing="5.0">
            <Label text="Placa del Vehículo:" />
            <TextField fx:id="txtPlaca" promptText="XYZ-123" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Mano de Obra ($):" />
            <TextField fx:id="txtManoObra" promptText="0.00" text="0" />
        </VBox>
    </HBox>

    <VBox spacing="10.0">
        <Label text="Agregar Repuesto">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="txtDescRepuesto" promptText="Descripción" prefWidth="250.0"/>
            <TextField fx:id="txtPrecioRepuesto" promptText="Precio" prefWidth="100.0"/>
            <Button text="Añadir" onAction="#agregarRepuestoAction" styleClass="primary-button" />
            <Button text="Quitar Seleccionado" onAction="#eliminarRepuestoAction" styleClass="danger-button" />
        </HBox>
    </VBox>

    <TableView fx:id="tablaRepuestos" prefHeight="200.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDescripcion" text="Descripción del Repuesto" prefWidth="400.0" />
            <TableColumn fx:id="colPrecio" text="Valor ($)" prefWidth="150.0" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="20.0">
        <Label fx:id="lblTotal" text="Total: $0.00" styleClass="total-label">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Button text="Guardar Factura" onAction="#generarFacturaAction" styleClass="warning-button" />
    </HBox>
</VBox>
